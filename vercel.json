{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/app/main.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "maxDuration": 120,
      "memory": 3008,
      "includeFiles": ["Model/**"]
    }
  }
}
